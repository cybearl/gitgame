{
    // Languages
    "[typescript][typescriptreact][javascript][css][json][jsonc]": {
        "editor.codeActionsOnSave": {
            "source.action.useSortedAttributes.biome": "explicit",
            "source.action.useSortedKeys.biome": "explicit",
            "source.action.useSortedProperties.biome": "explicit",
            "source.fixAll.biome": "explicit",
            "source.fixAll.eslint": "explicit",
            "source.organizeImports.biome": "explicit"
        },
        "editor.defaultFormatter": "biomejs.biome",
        "editor.formatOnSave": true
    },
    // Exclude common build and cache directories from the file explorer
    "files.exclude": {
        "**/.git": true,
        "**/.svn": true,
        "**/.hg": true,
        "**/.DS_Store": true,
        "**/Thumbs.db": true,
        ".git": true,
        ".pytest_cache": true,
        "**/__pycache__": true,
        "**/.augment": true,
        "**/.classpath": true,
        "**/.codex": true,
        "**/.contentlayer": true,
        "**/.cursor": true,
        "**/.dart_tool": true,
        "**/.factorypath": true,
        "**/.gemini": true,
        "**/.gitattributes": true,
        "**/.idea": true,
        "**/.idx": true,
        "**/.junie": true,
        "**/.metadata": true,
        "**/.next": true,
        "**/.nyc_output": true,
        "**/.openhands": true,
        "**/.packages": true,
        "**/.project": true,
        "**/.pytest_cache": true,
        "**/.ruler": true,
        "**/.settings": true,
        "**/.windsurf": true,
        "**/.yarn": true,
        "**/.yarnrc": true,
        "**/blob_storage": true,
        "**/Cargo.lock": true,
        "**/contracts/src/cache": true,
        "**/contracts/src/deployments": true,
        "**/CVS": true,
        "**/next-env.d.ts": true,
        "**/pubspec.lock": true,
    },
    // CSpell
    "cSpell.words": [
        "asar",
        "asynciterable",
        "browsable",
        "fguid",
        "gatherable",
        "scrollview",
        "SOFTOBJECTPATH",
        "uasset"
    ],
    "[json]": {
        "editor.defaultFormatter": "biomejs.biome"
    },
    "javascript.preferences.importModuleSpecifier": "shortest",
    "typescript.preferences.importModuleSpecifier": "non-relative"
}
