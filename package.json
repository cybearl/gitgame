{
    "name": "@cybearl/gitgame",
    "version": "0.0.0-semantically-released",
    "productName": "gitgame",
    "description": "A small tool with a web interface to simplify UE5-based game development with Git LFS.",
    "author": "Cybearl <contact@cybearl.com> (https://www.cybearl.com/)",
    "license": "MIT",
    "private": true,
    "packageManager": "yarn@1.22.22",
    "homepage": "https://github.com/cybearl/gitgame",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/cybearl/gitgame.git"
    },
    "bugs": {
        "url": "https://github.com/cybearl/gitgame/issues"
    },
    "engines": {
        "node": ">=22.0.0"
    },
    "main": "./out/main/index.js",
    "scripts": {
        "postinstall": "node node_modules/electron/install.js",
        "dev": "electron-vite dev",
        "build": "electron-vite build",
        "preview": "electron-vite preview",
        "typecheck": "tsc --noEmit",
        "lint": "biome check",
        "lint:fix": "biome check --fix && biome format --write",
        "dist": "electron-vite build && electron-builder",
        "release": "npx semantic-release",
        "hooks:install": "node -e \"if(require('fs').existsSync('.git'))require('child_process').execSync('git config core.hooksPath .githooks',{stdio:'inherit'})\"",
        "prepare": "npm run hooks:install"
    },
    "dependencies": {
        "@cybearl/cypack": "^1.11.10",
        "@react95/icons": "^2.5.0",
        "electron-updater": "^6.3.9",
        "react95": "^4.0.0",
        "styled-components": "^6.4.3"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.5.2",
        "@tailwindcss/vite": "^4.3.1",
        "@types/node": "^24.12.2",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^5.0.0",
        "electron": "^42.5.0",
        "electron-builder": "^25.1.8",
        "electron-vite": "^5.0.0",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "tailwindcss": "^4.3.1",
        "typescript": "^5.8.3",
        "vite": "^7.0.0"
    },
    "resolutions": {
        "@types/node": "^24.12.2"
    }
}