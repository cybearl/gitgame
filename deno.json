{
    "version": "0.1.0",
    "tasks": {
        "dev": "deno run --allow-run --allow-read --allow-write --allow-env --allow-net main.ts",
        "build:windows": "deno compile --allow-run --allow-read --allow-write --allow-env --allow-net --target x86_64-pc-windows-msvc --output dist/gitgame.exe main.ts",
        "build:linux": "deno compile --allow-run --allow-read --allow-write --allow-env --allow-net --target x86_64-unknown-linux-gnu --output dist/gitgame main.ts",
        "build:mac": "deno compile --allow-run --allow-read --allow-write --allow-env --allow-net --target x86_64-apple-darwin --output dist/gitgame-mac main.ts"
    },
    "imports": {
        "@std/path": "jsr:@std/path@^1.0.0",
        "@std/fmt": "jsr:@std/fmt@^1.0.0",
        "cliffy/command": "jsr:@cliffy/command@^1.0.0-rc.7",
        "cliffy/prompt": "jsr:@cliffy/prompt@^1.0.0-rc.7"
    },
    "compilerOptions": {
        "strict": true,
        "lib": [
            "deno.window",
            "deno.ns",
            "esnext"
        ],
        "noImplicitAny": true,
        "noUncheckedIndexedAccess": true
    }
}